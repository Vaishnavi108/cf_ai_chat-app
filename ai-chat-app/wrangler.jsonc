{
  "name": "ai-chat-app",
  "main": "src/index.js",
  "compatibility_date": "2024-01-01",

  "ai": {
    "binding": "AI",
  },

  "durable_objects": {
    "bindings": [
      {
        "name": "CHAT",
        "class_name": "ChatRoom",
      },
    ],
  },

  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["ChatRoom"],
    },
  ],
}
